<!-- APPENDICES -->
<h1>Appendices</h1>
<h2>Appendix A: Core Kalman Filter Implementation Excerpt</h2>
<p style="font-family: monospace; background-color: #f4f4f4; padding: 10px; border: 1px solid #ccc;">
class KalmanFilter {<br>
&nbsp;&nbsp;constructor(q = 0.01, r = 0.1, p = 1, initialValue = 0) {<br>
&nbsp;&nbsp;&nbsp;&nbsp;this.q = q; // Process noise<br>
&nbsp;&nbsp;&nbsp;&nbsp;this.r = r; // Measurement noise<br>
&nbsp;&nbsp;&nbsp;&nbsp;this.p = p; // Estimation error covariance<br>
&nbsp;&nbsp;&nbsp;&nbsp;this.x = initialValue; // Estimated value<br>
&nbsp;&nbsp;}<br>
&nbsp;&nbsp;update(measurement) {<br>
&nbsp;&nbsp;&nbsp;&nbsp;// Prediction update<br>
&nbsp;&nbsp;&nbsp;&nbsp;this.p = this.p + this.q;<br>
&nbsp;&nbsp;&nbsp;&nbsp;// Measurement update<br>
&nbsp;&nbsp;&nbsp;&nbsp;this.k = this.p / (this.p + this.r); // Kalman Gain<br>
&nbsp;&nbsp;&nbsp;&nbsp;this.x = this.x + this.k * (measurement - this.x);<br>
&nbsp;&nbsp;&nbsp;&nbsp;this.p = (1 - this.k) * this.p;<br>
&nbsp;&nbsp;&nbsp;&nbsp;return this.x;<br>
&nbsp;&nbsp;}<br>
}
</p>

